const path     = require('path');
const { spawnSync, spawn } = require('child_process');
const readline = require('readline');

// ─── Paths ────────────────────────────────────────────────────────────────────
const SCRIPT_DIR   = __dirname;
const ENV_FILE     = path.join(SCRIPT_DIR, '.env');
const COMPOSE_FILE = path.join(SCRIPT_DIR, 'docker-compose.yml');
const STATE_FILE   = path.join(SCRIPT_DIR, '.registry.json');

// ─── Colours ──────────────────────────────────────────────────────────────────
const RED    = '\x1b[0;31m';
const GREEN  = '\x1b[0;32m';
const YELLOW = '\x1b[1;33m';
const CYAN   = '\x1b[0;36m';
const BOLD   = '\x1b[1m';
const NC     = '\x1b[0m';

const log  = (...a) => console.log(`${GREEN}✓${NC}  ${a.join(' ')}`);
const warn = (...a) => console.log(`${YELLOW}⚠${NC}  ${a.join(' ')}`);
const err  = (...a) => console.error(`${RED}✗${NC}  ${a.join(' ')}`);
const info = (...a) => console.log(`${CYAN}→${NC}  ${a.join(' ')}`);
const die  = (...a) => { err(...a); process.exit(1); };

// ─── Env ──────────────────────────────────────────────────────────────────────
let PROJECT_NAME     = 'tribe';
let DB_HOST          = 'tribe_mysql';
let DB_NAME          = '';
let DB_ROOT_PASSWORD = 'rootpassword';
let CONTACT_EMAIL    = 'your@email.com';

let TRIBE_PORT      = 12000;
let PHPMYADMIN_PORT = 12001;
let JUNCTION_PORT   = 12002;
let DIST_PORT       = 12003;
let DIST_PHP_PORT   = 12004;
let FILEBROWSER_PORT = 12005;

function loadEnv() {
  if (!fs.existsSync(ENV_FILE)) {
    die('.env not found. Copy .env.sample and fill in values.');
  }

  const raw = fs.readFileSync(ENV_FILE, 'utf8');
  for (const line of raw.split('\n')) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#')) continue;
    const eqIdx = trimmed.indexOf('=');
    if (eqIdx === -1) continue;
    const key = trimmed.slice(0, eqIdx).trim();
    const val = trimmed.slice(eqIdx + 1).trim().replace(/^(['"])(.*)\1$/, '$2');
    process.env[key] = val;
  }

  PROJECT_NAME     = process.env.PROJECT_NAME     || 'tribe';
  DB_HOST          = process.env.DB_HOST           || `${PROJECT_NAME}_mysql`;
  DB_NAME          = process.env.DB_NAME           || '';
  DB_ROOT_PASSWORD = process.env.DB_ROOT_PASSWORD  || 'rootpassword';
  CONTACT_EMAIL    = process.env.CONTACT_EMAIL     || 'your@email.com';

  TRIBE_PORT       = parseInt(process.env.TRIBE_PORT       || '12000', 10);
  PHPMYADMIN_PORT  = parseInt(process.env.PHPMYADMIN_PORT  || '12001', 10);
  JUNCTION_PORT    = parseInt(process.env.JUNCTION_PORT    || '12002', 10);
  DIST_PORT        = parseInt(process.env.DIST_PORT        || '12003', 10);
  DIST_PHP_PORT    = parseInt(process.env.DIST_PHP_PORT    || '12004', 10);
  FILEBROWSER_PORT = parseInt(process.env.FILEBROWSER_PORT || '12005', 10);
}

// ─── State (domain bindings) ──────────────────────────────────────────────────
// Persists domain bindings so they survive config rewrites.
function stateRead() {
  if (!fs.existsSync(STATE_FILE)) return {};
  try { return JSON.parse(fs.readFileSync(STATE_FILE, 'utf8')); } catch { return {}; }
}

function stateWrite(data) {
  fs.writeFileSync(STATE_FILE, JSON.stringify(data, null, 2));
}

function stateGet(key) {
  return stateRead()[key] || '';
}

function stateSet(key, value) {
  const data = stateRead();
  data[key] = value;
  stateWrite(data);
}

// ─── Docker compose helper ────────────────────────────────────────────────────
function dc(args, inherit = true) {
  if (!fs.existsSync(COMPOSE_FILE)) {
    die(`docker-compose.yml not found at: ${COMPOSE_FILE}`);
  }
  const result = spawnSync(
    'docker',
    ['compose', '-f', COMPOSE_FILE, ...args],
    { stdio: inherit ? 'inherit' : 'pipe' }
  );
  return result.status === 0;
}

// ─── Caddy config generators ──────────────────────────────────────────────────
function generateTribeCaddyfile(domain) {
  const siteAddr    = domain ? domain : ':80';
  const globalBlock = domain
    ? `{\n    admin off\n    email ${CONTACT_EMAIL}\n}`
    : `{\n    email {$CONTACT_EMAIL:your-name@your-collective.org}\n    admin off\n    local_certs\n}`;

  return `# Managed by tribe CLI — do not edit manually.
# To update, run: node tribe set-tribe-domain <domain>
${globalBlock}

${siteAddr} {
    root * /var/www/html

    header {
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer-when-downgrade"
        Content-Security-Policy "default-src * data: 'unsafe-eval' 'unsafe-inline'"
    }

    php_fastcgi php_tribe:9000 {
        trusted_proxies private_ranges
    }

    @hidden {
        path */.*
        not path */.well-known/*
    }
    respond @hidden 403

    @mysql_uploads {
        path /uploads/mysql/*
    }
    respond @mysql_uploads 403

    @uploads {
        path /uploads/*
    }
    route @uploads {
        try_files {path} /uploads.php{query}
    }

    @static {
        file
        path *.css *.gif *.ico *.webp *.jpeg *.jpg *.js *.png *.woff *.woff2 *.ttf *.eot
    }
    header @static {
        Cache-Control "public, max-age=31536000, immutable"
        Vary "Accept-Encoding"
    }

    file_server
    encode {
        gzip 6
        minimum_length 1000
    }

    log {
        output file /var/log/caddy/tribe_access.log {
            roll_size 100MiB
            roll_keep 5
            roll_keep_for 24h
        }
        format json
        level INFO
    }
}
`;
}

