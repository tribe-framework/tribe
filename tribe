#!/usr/bin/env node
// ══════════════════════════════════════════════════════════════════════════════
// tribe — Tribe instance management CLI
//
// Commands:
//   node tribe start                       Start all containers
//   node tribe stop                        Stop all containers (with DB backup)
//   node tribe logs            [svc]       Tail logs for all or a specific service
//   node tribe status                      Show container status
//   node tribe set-junction-password [pw]  Update JUNCTION_PASSWORD and restart junction
//   node tribe set-tribe-domain     <domain>       Bind tribe to domain + auto-SSL
//   node tribe set-phpmyadmin-domain <domain>      Bind phpMyAdmin to domain + auto-SSL
//   node tribe set-junction-domain  <domain>       Bind junction to domain + auto-SSL
//   node tribe set-dist-domain      <domain>       Bind dist (static) to domain + auto-SSL
//   node tribe set-dist-php-domain  <domain>       Bind dist-php to domain + auto-SSL
//   node tribe set-filebrowser-domain <domain>     Bind filebrowser to domain + auto-SSL
//
// Prerequisites:
//   - Docker installed and running
//   - .env file present in the same directory as this script
//   - docker-compose.yml present in the same directory as this script
//
// Directory layout (everything self-contained here):
//   ./
//     docker-compose.yml
//     .env
//     config/tribe/Caddyfile
//     config/tribe/supervisord.conf
//     config/junction/Caddyfile
//     config/dist/Caddyfile
//     config/dist-php/Caddyfile
//     config/backup.sh
//     applications/tribe/
//     applications/junction/
//     uploads/
//     logs/
//
// ══════════════════════════════════════════════════════════════════════════════

'use strict';

