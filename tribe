  }

  info(`Writing dist-php Caddyfile for domain '${domain}'...`);
  fs.writeFileSync(caddyfile, generateDistPhpCaddyfile(domain));

  ensurePort443InCompose('caddy_php_dist');
  stateSet('dist_php_domain', domain);

  info('Restarting caddy_php_dist...');
  dc(['up', '-d', '--no-deps', 'caddy_php_dist']);

  console.log('');
  log(`Dist PHP domain set: https://${domain}`);
  warn("Make sure ports 80 and 443 are open in your firewall.");
  warn("Caddy will obtain a Let's Encrypt certificate automatically on first request.");
  console.log('');
}

function cmdSetFilebrowserDomain(domain) {
  if (!domain) die('Usage: node tribe set-filebrowser-domain <domain>');
  loadEnv();
  validateDomain(domain);

  // FileBrowser, like phpMyAdmin, has its own HTTP server rather than Caddy.
  // Store the domain in state and expose 443 for proxy use.
  ensurePort443InCompose('filebrowser');
  stateSet('filebrowser_domain', domain);

  info('Restarting filebrowser...');
  dc(['up', '-d', '--no-deps', 'filebrowser']);

  console.log('');
  log(`Filebrowser domain recorded: https://${domain}`);
  warn('Filebrowser does not use Caddy — point your reverse proxy or DNS to this server.');
  warn("Make sure ports 80 and 443 are open in your firewall.");
  console.log('');
}

// ─── usage ────────────────────────────────────────────────────────────────────
function usage() {
  console.log(`
${BOLD}Usage:${NC} node tribe <command> [args]

${BOLD}Lifecycle:${NC}
  start                        Start all containers
  stop                         Stop all containers (creates DB backup first)
  logs              [service]  Tail logs — all services or a specific one
  status                       Show container status and domain bindings

${BOLD}Configuration:${NC}
  set-junction-password [pw]   Update JUNCTION_PASSWORD and restart junction

${BOLD}Domain / SSL${NC} (A or CNAME must already point at this server):
  set-tribe-domain        <domain>   Bind tribe to domain + auto-SSL via Caddy
  set-phpmyadmin-domain   <domain>   Record phpMyAdmin domain (manual proxy needed)
  set-junction-domain     <domain>   Bind junction to domain + auto-SSL via Caddy
  set-dist-domain         <domain>   Bind dist (static) to domain + auto-SSL via Caddy
  set-dist-php-domain     <domain>   Bind dist-php to domain + auto-SSL via Caddy
  set-filebrowser-domain  <domain>   Record filebrowser domain (manual proxy needed)

${BOLD}Valid service names for logs:${NC}
  mysql  setup  php_tribe  php_junction  php_dist  mysql_backup
  caddy_tribe  phpmyadmin  caddy_junction  caddy_dist  caddy_php_dist
  filebrowser  typesense
`);
  process.exit(1);
}

// ─── Dispatch ─────────────────────────────────────────────────────────────────
(async () => {
  const [,, cmd, arg1] = process.argv;

  switch (cmd) {
    case 'start':                   cmdStart();                        break;
    case 'stop':                    cmdStop();                         break;
    case 'logs':                    cmdLogs(arg1);                     break;
    case 'status':                  cmdStatus();                       break;
    case 'set-junction-password':   await cmdSetJunctionPassword();    break;
    case 'set-tribe-domain':        cmdSetTribeDomain(arg1);           break;
    case 'set-phpmyadmin-domain':   cmdSetPhpMyAdminDomain(arg1);      break;
    case 'set-junction-domain':     cmdSetJunctionDomain(arg1);        break;
    case 'set-dist-domain':         cmdSetDistDomain(arg1);            break;
    case 'set-dist-php-domain':     cmdSetDistPhpDomain(arg1);         break;
    case 'set-filebrowser-domain':  cmdSetFilebrowserDomain(arg1);     break;
    default:                        usage();
  }
})();
