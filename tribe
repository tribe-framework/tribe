// ─── Domain helpers ───────────────────────────────────────────────────────────
function validateDomain(domain) {
  if (!domain || !domain.includes('.')) {
    die(`'${domain}' does not look like a valid domain name.`);
  }
  if (/\s/.test(domain)) {
    die(`Domain must not contain spaces: '${domain}'`);
  }
}

// Rewrites docker-compose.yml to expose port 443 for services that have
// a domain bound.  Reads the existing compose file, replaces the ports
// block for the named service using a simple but reliable regex approach,
// then writes it back.  We only touch the ports list — everything else is
// left exactly as-is so manual edits are not clobbered.
function ensurePort443InCompose(service) {
  if (!fs.existsSync(COMPOSE_FILE)) return;

  let content = fs.readFileSync(COMPOSE_FILE, 'utf8');

  // Build a regex that matches the ports block of the target service.
  // We look for a pattern like:
  //   ports:
  //     - "12000:80"
  // and replace / augment it with a 443:443 entry if not already present.
  const portLineRe = new RegExp(
    `(  ${service}:[\\s\\S]*?ports:\\s*\\n(?:[ \\t]+-[ \\t]+["']?[^\\n]+["']?\\n)*)`,
    'g'
  );

  content = content.replace(portLineRe, (match) => {
    if (match.includes('443:443')) return match;                 // already there
    // Append 443 entry after last ports line
    return match.replace(/([ \t]+-[ \t]+["']?\d+:80["']?\n)(?![ \t]+-)/,
      `$1      - "443:443"\n`);
  });

  fs.writeFileSync(COMPOSE_FILE, content);
}

// ─── On-demand MySQL backup ───────────────────────────────────────────────────
function mysqlBackupNow() {
  if (!DB_NAME) {
    warn('DB_NAME not set in .env — skipping pre-stop backup.');
    return false;
  }

  const backupDir  = path.join(SCRIPT_DIR, 'uploads', 'backups');
  const dateTag    = new Date().toISOString().replace(/[-:T]/g, '').slice(0, 15);
  const backupFile = path.join(backupDir, `${PROJECT_NAME}_backup_${dateTag}.sql.gz`);

  fs.mkdirSync(backupDir, { recursive: true });
  info('Creating MySQL backup before shutdown...');

  const dump = spawnSync(
    'docker',
    [
      'exec', DB_HOST,
      'mysqldump',
      '-u', 'root', `-p${DB_ROOT_PASSWORD}`,
      '--single-transaction', '--routines', '--triggers',
      DB_NAME,
    ],
    { stdio: ['pipe', 'pipe', 'pipe'] }
  );

  if (dump.status !== 0) {
    warn(`Backup failed (mysqldump exited ${dump.status}): ${(dump.stderr || '').toString().trim()}`);
    return false;
  }

  const gzip = spawnSync('gzip', ['-c'], { input: dump.stdout, stdio: ['pipe', 'pipe', 'pipe'] });
  if (gzip.status !== 0) {
    warn('Backup failed: gzip error.');
    return false;
  }

  fs.writeFileSync(backupFile, gzip.stdout);
  log(`Backup saved: ${backupFile}`);
  return true;
}

// ─── Prompt helper ────────────────────────────────────────────────────────────
function prompt(question) {
  return new Promise(resolve => {
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    rl.question(question, answer => { rl.close(); resolve(answer); });
  });
}

