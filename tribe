// ─── start ────────────────────────────────────────────────────────────────────
function cmdStart() {
  loadEnv();
  info('Starting Tribe containers...');
  dc(['up', '-d']);
  console.log('');
  log('Tribe is up!');
  console.log('');
  console.log(`  ${CYAN}Tribe:${NC}       http://localhost:${TRIBE_PORT}`);
  console.log(`  ${CYAN}phpMyAdmin:${NC}  http://localhost:${PHPMYADMIN_PORT}`);
  console.log(`  ${CYAN}Junction:${NC}    http://localhost:${JUNCTION_PORT}`);
  console.log(`  ${CYAN}Dist:${NC}        http://localhost:${DIST_PORT}`);
  console.log(`  ${CYAN}Dist PHP:${NC}    http://localhost:${DIST_PHP_PORT}`);
  console.log(`  ${CYAN}Filebrowser:${NC} http://localhost:${FILEBROWSER_PORT}`);
  console.log('');
}

// ─── stop ─────────────────────────────────────────────────────────────────────
function cmdStop() {
  loadEnv();
  mysqlBackupNow();
  info('Stopping Tribe containers...');
  dc(['stop']);
  log('Tribe stopped.');
}

// ─── logs ─────────────────────────────────────────────────────────────────────
function cmdLogs(service) {
  loadEnv();

  // Validate service name if provided
  const validServices = [
    'mysql', 'setup', 'php_tribe', 'php_junction', 'php_dist',
    'mysql_backup', 'caddy_tribe', 'phpmyadmin', 'caddy_junction',
    'caddy_dist', 'caddy_php_dist', 'filebrowser', 'typesense',
  ];

  if (service && !validServices.includes(service)) {
    warn(`Unknown service '${service}'. Valid services:`);
    console.log(`  ${validServices.join('  ')}`);
    console.log('');
    warn('Showing all logs instead...');
    service = null;
  }

  const args = ['compose', '-f', COMPOSE_FILE, 'logs', '-f', '--tail=100'];
  if (service) args.push(service);

  const child = spawn('docker', args, { stdio: 'inherit' });
  child.on('exit', code => process.exit(code || 0));
}

// ─── status ───────────────────────────────────────────────────────────────────
function cmdStatus() {
  loadEnv();

  console.log('');
  console.log(`${BOLD}Tribe Status${NC}`);
  console.log('────────────────────────────────────────────────────────────────');

  // Show docker compose ps output
  dc(['ps']);

  // Also show domain bindings from state
  const state = stateRead();
  const domains = {
    tribe:       state.tribe_domain       || '(none)',
    phpmyadmin:  state.phpmyadmin_domain  || '(none)',
    junction:    state.junction_domain    || '(none)',
    dist:        state.dist_domain        || '(none)',
    'dist-php':  state.dist_php_domain    || '(none)',
    filebrowser: state.filebrowser_domain || '(none)',
  };

  const hasDomains = Object.values(domains).some(d => d !== '(none)');
  if (hasDomains) {
    console.log('');
    console.log(`${BOLD}Domain Bindings${NC}`);
    for (const [svc, domain] of Object.entries(domains)) {
      const label = `${svc}:`.padEnd(14);
      const display = domain === '(none)'
        ? `${YELLOW}${domain}${NC}`
        : `${GREEN}https://${domain}${NC}`;
      console.log(`  ${CYAN}${label}${NC} ${display}`);
    }
  }

  console.log('');
}

// ─── set-junction-password ────────────────────────────────────────────────────
async function cmdSetJunctionPassword() {
  loadEnv();

  if (!fs.existsSync(ENV_FILE)) die(`.env not found at ${ENV_FILE}`);

  let newPassword = process.argv[3] || '';
  if (!newPassword) {
    newPassword = await prompt('New JUNCTION_PASSWORD: ');
  }
  newPassword = newPassword.trim();
  if (!newPassword) die('Password cannot be empty.');

  let envContent = fs.readFileSync(ENV_FILE, 'utf8');

  if (/^JUNCTION_PASSWORD=.*$/m.test(envContent)) {
    envContent = envContent.replace(/^JUNCTION_PASSWORD=.*$/m, `JUNCTION_PASSWORD=${newPassword}`);
    info('Updated existing JUNCTION_PASSWORD in .env.');
  } else {
    envContent += `\nJUNCTION_PASSWORD=${newPassword}\n`;
    warn('JUNCTION_PASSWORD was not present — appended to .env.');
  }

  fs.writeFileSync(ENV_FILE, envContent);
  log('.env updated.');

  info('Restarting junction containers...');
  dc(['restart', 'php_junction', 'caddy_junction']);
  log('Junction containers restarted. JUNCTION_PASSWORD is now active.');
}

// ─── Domain commands (shared implementation) ──────────────────────────────────
//
// For each service:
//   1. Validate the domain
//   2. Rewrite the relevant Caddyfile so Caddy uses the domain (triggers ACME)
//   3. Ensure port 443 is exposed in docker-compose.yml for that service
//   4. Persist the domain in .registry.json for future reference
//   5. Reload only the affected Caddy container
//
// Prerequisites the caller must have handled:
//   - A / CNAME record for the domain already points at this server
//   - Ports 80 and 443 are open in the firewall

function cmdSetTribeDomain(domain) {
  if (!domain) die('Usage: node tribe set-tribe-domain <domain>');
  loadEnv();
  validateDomain(domain);

  const caddyfile = path.join(SCRIPT_DIR, 'config', 'tribe', 'Caddyfile');
  if (!fs.existsSync(path.dirname(caddyfile))) {
    die(`Config directory not found: ${path.dirname(caddyfile)}`);
  }

  info(`Writing tribe Caddyfile for domain '${domain}'...`);
  fs.writeFileSync(caddyfile, generateTribeCaddyfile(domain));

  ensurePort443InCompose('caddy_tribe');
  stateSet('tribe_domain', domain);

  info('Restarting caddy_tribe...');
  dc(['up', '-d', '--no-deps', 'caddy_tribe']);

  console.log('');
  log(`Tribe domain set: https://${domain}`);
  warn("Make sure ports 80 and 443 are open in your firewall.");
  warn("Caddy will obtain a Let's Encrypt certificate automatically on first request.");
  console.log('');
}

function cmdSetPhpMyAdminDomain(domain) {
  if (!domain) die('Usage: node tribe set-phpmyadmin-domain <domain>');
  loadEnv();
  validateDomain(domain);

  // phpMyAdmin doesn't have its own Caddyfile — it uses its own HTTP listener.
  // We front it with a minimal Caddy reverse-proxy config file if present,
  // or we simply ensure 443 is exposed and store the domain in state.
  // The most common setup is to let a separate reverse proxy (e.g. Caddy on
  // the host or a separate container) handle TLS termination for phpMyAdmin.
  // Here we store the intent and expose 443, consistent with other services.
  ensurePort443InCompose('phpmyadmin');
  stateSet('phpmyadmin_domain', domain);

  info('Restarting phpmyadmin...');
  dc(['up', '-d', '--no-deps', 'phpmyadmin']);

  console.log('');
  log(`phpMyAdmin domain recorded: https://${domain}`);
  warn('phpMyAdmin does not use Caddy — point your reverse proxy or DNS to this server.');
  warn("Make sure ports 80 and 443 are open in your firewall.");
  console.log('');
}

