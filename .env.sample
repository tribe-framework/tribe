# ══════════════════════════════════════════════════════════════════════════════
# Tribe Framework — Environment Configuration
# Copy this file to .env and fill in your values before running docker compose.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Project Identity ─────────────────────────────────────────────────────────
# Used as a prefix for all Docker container names (e.g. myproject_mysql).
# Lowercase letters, numbers, and hyphens only — NO spaces, NO uppercase.
PROJECT_NAME=tribe

# ─── Application ──────────────────────────────────────────────────────────────
# Show PHP errors in the browser. Set to false in production.
DISPLAY_ERRORS=false

# PHP/app timezone. See: https://www.php.net/manual/en/timezones.php
DEFAULT_TIMEZONE=Asia/Kolkata

# Your site's domain without protocol or trailing slash.
# Use "localhost" for local dev, or "example.com" for production.
BARE_URL=localhost

# Contact email used by Caddy when requesting SSL certificates (production only).
CONTACT_EMAIL=your-name@your-collective.org

# ─── Database ─────────────────────────────────────────────────────────────────
# Change ALL passwords before deploying. Do not use the defaults in production.
DB_ROOT_PASSWORD=rootpassword
DB_NAME=tribe_db
DB_USER=tribe_user
DB_PASS=userpassword

# DB_HOST must match PROJECT_NAME + "_mysql" (set automatically by convention).
# Only change this if you know what you're doing.
DB_HOST=tribe_mysql

# Host port MySQL is exposed on. 12006 is the default; change if it conflicts.
DB_PORT=12006

# ─── Ports ────────────────────────────────────────────────────────────────────
# Each service is exposed on a separate host port.
# Change any of these if they conflict with other services on your machine.

# Main Tribe PHP application
TRIBE_PORT=12000

# phpMyAdmin database GUI
PHPMYADMIN_PORT=12001

# Junction frontend
JUNCTION_PORT=12002

# Static site (dist folder — HTML/JS/CSS only)
DIST_PORT=12003

# Dynamic PHP site (dist-php folder)
DIST_PHP_PORT=12004

# FileBrowser file manager
FILEBROWSER_PORT=12005

# Typesense search engine (also accessible internally on port 8108)
TYPESENSE_PORT=12007

# ─── Junction ─────────────────────────────────────────────────────────────────
# URL slug Junction is served under (e.g. /junction)
JUNCTION_SLUG=junction

# Password to access the Junction admin interface
JUNCTION_PASSWORD=password

# Internal URL that Junction uses to call the Tribe API.
# In production with a real domain, change localhost to your domain.
TRIBE_API_URL=http://localhost:12000

# API key for Tribe → used by Junction to authenticate requests.
# Leave empty to disable API key auth.
TRIBE_API_KEY=

# ─── Plausible Analytics (optional) ──────────────────────────────────────────
# Leave both empty to disable Plausible.
# PLAUSIBLE_AUTH format: "user:password" (basic auth for self-hosted instances)
PLAUSIBLE_AUTH=
PLAUSIBLE_DOMAIN=

# ─── FileBrowser ──────────────────────────────────────────────────────────────
# Password for the default "admin" user in FileBrowser.
FILEBROWSER_PASSWORD=filepassword

# ─── Typesense ────────────────────────────────────────────────────────────────
# API key used to authenticate requests to Typesense.
# Change this to a strong random string in production (e.g. `openssl rand -hex 32`).
TYPESENSE_API_KEY=xyz

# Set to true to enable the Typesense-powered file search in the Tribe UI.
# The indexer always runs regardless of this flag — this only affects the UI.
TYPESENSE_ENABLED=true
TYPESENSE_SHOW_PUBLIC_OBJECTS_ONLY=true
TYPESENSE_HIDE_UPLOADS_FOLDER_RESULTS=true

# ─── Hide Postcode Attribution ────────────────────────────────────────────────
# Set to true to remove postcode data source attribution from the UI.
HIDE_POSTCODE_ATTRIBUTION=false
