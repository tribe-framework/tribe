# ══════════════════════════════════════════════════════════════════════════════
# Tribe Thread — Environment Configuration
# Copy this file to .env and fill in your values before running docker compose.
#
# A tribe-thread is a self-contained Tribe instance that shares tribe-loom's
# MySQL. It has its own database, its own Typesense, and its own port block.
#
# PORT BLOCK CONVENTION
# ─────────────────────
# Every thread occupies a 10-port block ending in 0–9.
# Assign a unique block per thread to avoid host-port collisions.
# Examples:  13000–13009 (first thread)
#            14000–14009 (second thread)
#            15000–15009 (third thread)  etc.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Project Identity ─────────────────────────────────────────────────────────
# Unique name for this thread. Used as a prefix for all container names.
# Lowercase, numbers, hyphens only. Must be different from loom and all other threads.
PROJECT_NAME=thread1

# ─── tribe-loom reference ─────────────────────────────────────────────────────
# PROJECT_NAME of the parent tribe-loom instance.
# Used to locate loom's shared Docker network and MySQL container.
LOOM_PROJECT_NAME=loom

# ─── Application ──────────────────────────────────────────────────────────────
DISPLAY_ERRORS=false
DEFAULT_TIMEZONE=Asia/Kolkata
BARE_URL=localhost
CONTACT_EMAIL=your-name@your-collective.org

# ─── Database — connects to loom's shared MySQL ───────────────────────────────
# DB_HOST must resolve inside Docker: it is loom's MySQL container name,
# which follows the pattern <LOOM_PROJECT_NAME>_mysql.
DB_HOST=loom_mysql

# This thread's own database and dedicated user (NOT the loom root credentials).
# setup.sh provisions these automatically on first run.
DB_NAME=thread1_db
DB_USER=thread1_user
DB_PASS=userpassword

# DB_ROOT_PASSWORD is only needed by setup.sh to provision the DB/user.
# It must match the DB_ROOT_PASSWORD set in tribe-loom's .env.
DB_ROOT_PASSWORD=rootpassword

# ─── Ports — assign a unique 10-port block per thread ────────────────────────
# Replace 130 with your chosen block prefix (e.g. 130xx, 131xx, 132xx …)
TRIBE_PORT=13000
# 13001 reserved (phpMyAdmin lives only on loom)
JUNCTION_PORT=13002
DIST_PORT=13003
DIST_PHP_PORT=13004
# 13005 reserved (FileBrowser lives only on loom)
# 13006 reserved (MySQL lives only on loom)
TYPESENSE_PORT=13007
# 13008 reserved
# 13009 reserved

# ─── Junction ─────────────────────────────────────────────────────────────────
JUNCTION_SLUG=junction
JUNCTION_PASSWORD=password
TRIBE_API_URL=http://localhost:13000
TRIBE_API_KEY=

# ─── Plausible Analytics (optional) ──────────────────────────────────────────
PLAUSIBLE_AUTH=
PLAUSIBLE_DOMAIN=

# ─── Typesense — private to this thread ──────────────────────────────────────
TYPESENSE_API_KEY=xyz
TYPESENSE_ENABLED=true
TYPESENSE_SHOW_PUBLIC_OBJECTS_ONLY=true
TYPESENSE_HIDE_UPLOADS_FOLDER_RESULTS=true

# ─── Hide Postcode Attribution ────────────────────────────────────────────────
HIDE_POSTCODE_ATTRIBUTION=false
