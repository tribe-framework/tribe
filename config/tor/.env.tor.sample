# ══════════════════════════════════════════════════════════════════════════════
# Tribe Framework — Environment Configuration
# Copy this file to .env and fill in your values before running docker compose.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Project Identity ─────────────────────────────────────────────────────────
PROJECT_NAME=tribe

# ─── Application ──────────────────────────────────────────────────────────────
DISPLAY_ERRORS=false
DEFAULT_TIMEZONE=Asia/Kolkata

# Your site's domain without protocol or trailing slash.
# Clearnet: "localhost" or "example.com"
# Tor:      leave as "localhost" — real hostname comes from uploads/tor/tribe/hostname
BARE_URL=localhost

CONTACT_EMAIL=your-name@your-collective.org

# ─── Database ─────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword
DB_NAME=tribe_db
DB_USER=tribe_user
DB_PASS=userpassword
DB_PORT=3306
DB_HOST=tribe_mysql

# ─── Ports ────────────────────────────────────────────────────────────────────
# Used in clearnet mode only.
# In Tor mode these values are ignored — no ports are exposed on the host.
TRIBE_PORT=12000
PHPMYADMIN_PORT=12001
JUNCTION_PORT=12002
DIST_PORT=12003
DIST_PHP_PORT=12004
FILEBROWSER_PORT=12005

# ─── Junction ─────────────────────────────────────────────────────────────────
JUNCTION_SLUG=junction
JUNCTION_PASSWORD=password

# Clearnet: http://localhost:12000
# Tor:      http://<tribe-onion>.onion  (read from uploads/tor/tribe/hostname)
TRIBE_API_URL=http://localhost:12000

TRIBE_API_KEY=

# ─── Plausible Analytics (optional) ──────────────────────────────────────────
# WARNING: Do NOT use a clearnet analytics service in Tor mode —
# it deanonymises visitors. Self-host Plausible as a hidden service or leave blank.
PLAUSIBLE_AUTH=
PLAUSIBLE_DOMAIN=

# ─── FileBrowser ──────────────────────────────────────────────────────────────
FILEBROWSER_PASSWORD=filepassword

# ─── Deepsearch (Meilisearch) ─────────────────────────────────────────────────
DEEPSEARCH_API_KEY=xyz
DEEPSEARCH_ENABLED=true
DEEPSEARCH_SHOW_PUBLIC_OBJECTS_ONLY=true
DEEPSEARCH_SHOW_UPLOADS_FOLDER_RESULTS=false

# ─── Hide Postcode Attribution ────────────────────────────────────────────────
HIDE_POSTCODE_ATTRIBUTION=false
