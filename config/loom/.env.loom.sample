# ══════════════════════════════════════════════════════════════════════════════
# Loom — Environment Configuration
# cp .env.loom.sample .env.loom
# ══════════════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=Asia/Kolkata
BARE_URL=localhost
CONTACT_EMAIL=your@email.com

# ─── Database ─────────────────────────────────────────────────────────────────
# Root password for the shared loom_mysql container.
# Thread DB users are provisioned automatically by loom.sh.
DB_ROOT_PASSWORD=rootpassword

# ─── Typesense ────────────────────────────────────────────────────────────────
TYPESENSE_API_KEY=change-me-in-production

# ─── Shared Service Ports ─────────────────────────────────────────────────────
PHPMYADMIN_PORT=12001
FILEBROWSER_PORT=12005

# ─── FileBrowser ──────────────────────────────────────────────────────────────
FILEBROWSER_PASSWORD=change-me-in-production

# ─── Thread Port Allocation ───────────────────────────────────────────────────
# loom.sh allocates ports starting here, incrementing by 2 per thread.
# Thread 1: TRIBE=13000, JUNCTION=13001
# Thread 2: TRIBE=13002, JUNCTION=13003
# …
THREAD_BASE_PORT=13000
