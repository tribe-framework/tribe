// ─── MySQL provisioning ───────────────────────────────────────────────────────
function mysqlExec(sql) {
  const result = spawnSync(
    'docker',
    ['exec', '-i', LOOM_MYSQL_CONTAINER, 'mysql', '-u', 'root', `-p${DB_ROOT_PASSWORD}`, '-sN', '-e', sql],
    { stdio: ['pipe', 'pipe', 'pipe'] }
  );
  if (result.status !== 0) return false;
  return true;
}

function provisionDb(dbName, dbUser, dbPass) {
  info(`Creating database '${dbName}'...`);
  if (!mysqlExec(`CREATE DATABASE IF NOT EXISTS \`${dbName}\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;`)) {
    die(`Failed to create database '${dbName}'`);
  }

  info(`Creating user '${dbUser}'...`);
  if (!mysqlExec(`CREATE USER IF NOT EXISTS '${dbUser}'@'%' IDENTIFIED BY '${dbPass}';`)) {
    die(`Failed to create user '${dbUser}'`);
  }

  info('Granting privileges...');
  if (!mysqlExec(`GRANT ALL PRIVILEGES ON \`${dbName}\`.* TO '${dbUser}'@'%'; FLUSH PRIVILEGES;`)) {
    die(`Failed to grant privileges`);
  }

  const schema = path.join(SCRIPT_DIR, 'config', 'mysql', 'install.sql');
  if (fs.existsSync(schema)) {
    info('Importing schema from config/mysql/install.sql...');
    const schemaData = fs.readFileSync(schema);
    const result = spawnSync(
      'docker',
      ['exec', '-i', LOOM_MYSQL_CONTAINER, 'mysql', '-u', 'root', `-p${DB_ROOT_PASSWORD}`, dbName],
      { input: schemaData, stdio: ['pipe', 'pipe', 'pipe'] }
    );
    if (result.status !== 0) die('Failed to import schema');
    log('Schema imported.');
  } else {
    warn('config/mysql/install.sql not found — skipping schema import.');
  }
}

function dropDb(dbName, dbUser) {
  warn(`Dropping database '${dbName}' and user '${dbUser}'...`);
  mysqlExec(`DROP DATABASE IF EXISTS \`${dbName}\`;`);
  mysqlExec(`DROP USER IF EXISTS '${dbUser}'@'%'; FLUSH PRIVILEGES;`);
  log('Database and user removed.');
}

// ─── Random password ─────────────────────────────────────────────────────────
function randomPass() {
  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
  let result = '';
  for (let i = 0; i < 24; i++) {
    result += chars[crypto.randomInt(chars.length)];
  }
  return result;
}

// ─── Prompt helper ────────────────────────────────────────────────────────────
function prompt(question) {
  return new Promise(resolve => {
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    rl.question(question, answer => {
      rl.close();
      resolve(answer);
    });
  });
}

// ─── Docker compose helper ────────────────────────────────────────────────────
function dockerCompose(composeFile, args, inherit = true) {
  const result = spawnSync(
    'docker',
    ['compose', '-f', composeFile, ...args],
    { stdio: inherit ? 'inherit' : 'pipe' }
  );
  return result.status === 0;
}

// ═══════════════════════════════════════════════════════════════════════════════
//  COMMANDS
// ═══════════════════════════════════════════════════════════════════════════════

async function cmdCreate(name) {
  if (!name) die('Usage: loom.js create <n>');

  loadEnv();
  validateName(name);
  checkPrerequisites();
  registryInit();

  if (registryHas(name)) {
    die(`Thread '${name}' already exists. Use 'loom.js start ${name}' or 'loom.js destroy ${name}' first.`);
  }

  // ── Allocate ports ──────────────────────────────────────────────────────────
  // Each thread reserves a block of 10 ports (xxxx0–xxxx9):
  //   +0  Tribe
  //   +1  (reserved)
  //   +2  Junction
  //   +3  Dist (static)
  //   +4  Dist (PHP)
  //   +5–+9  (reserved)
  const basePort     = registryNextPort();
  const tribePort    = basePort + 0;
  const junctionPort = basePort + 2;
  const distPort     = basePort + 3;
  const distPhpPort  = basePort + 4;

  console.log('');
  console.log(`${BOLD}Creating Thread: ${CYAN}${name}${NC}`);
  console.log(`  Base port:     ${basePort}  (block ${basePort}–${basePort + 9})`);
  console.log(`  Tribe port:    ${tribePort}`);
  console.log(`  Junction port: ${junctionPort}`);
  console.log(`  Dist port:     ${distPort}`);
  console.log(`  Dist PHP port: ${distPhpPort}`);
  console.log('');

  // ── DB credentials ──────────────────────────────────────────────────────────
  const safeName = name.replace(/-/g, '_');
  const dbName   = `${PROJECT_NAME}_${safeName}_db`;
  const dbUser   = `${PROJECT_NAME}_${safeName}_user`;
  const dbPass   = randomPass();

  // ── Directory structure ─────────────────────────────────────────────────────
  // Everything lives inside threads/<name>/ for a fully self-contained thread.
  const threadDir = path.join(THREADS_DIR, name);
  fs.mkdirSync(path.join(threadDir, 'config', 'tribe'),               { recursive: true });
  fs.mkdirSync(path.join(threadDir, 'config', 'junction'),            { recursive: true });
  fs.mkdirSync(path.join(threadDir, 'config', 'dist'),                { recursive: true });
  fs.mkdirSync(path.join(threadDir, 'config', 'dist-php'),            { recursive: true });
  fs.mkdirSync(path.join(threadDir, 'applications', 'tribe', 'custom'), { recursive: true });
  fs.mkdirSync(path.join(threadDir, 'uploads'),                       { recursive: true });
  fs.mkdirSync(path.join(threadDir, 'logs'),                          { recursive: true });

  // ── Generate configs ────────────────────────────────────────────────────────
  info('Generating Caddyfiles...');
  fs.writeFileSync(path.join(threadDir, 'config', 'tribe',    'Caddyfile'), generateTribeCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'junction', 'Caddyfile'), generateJunctionCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'dist',     'Caddyfile'), generateDistCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'dist-php', 'Caddyfile'), generateDistPhpCaddyfile(name));

  info('Copying supervisord.conf...');
  if (!fs.existsSync(SUPERVISORD_CONF)) die(`supervisord.conf not found at: ${SUPERVISORD_CONF}`);
  fs.copyFileSync(SUPERVISORD_CONF, path.join(threadDir, 'config', 'tribe', 'supervisord.conf'));

  info('Copying backup.sh...');
  if (!fs.existsSync(BACKUP_SH)) die(`backup.sh not found at: ${BACKUP_SH}`);
  fs.copyFileSync(BACKUP_SH, path.join(threadDir, 'config', 'backup.sh'));

  info('Generating docker-compose.yml...');
  fs.writeFileSync(path.join(threadDir, 'docker-compose.yml'), generateThreadCompose(name, tribePort, junctionPort, distPort, distPhpPort));

  info('Generating .env...');
  const threadEnvFile = path.join(threadDir, '.env');
  let effectiveDbPass = dbPass;
  if (!fs.existsSync(threadEnvFile)) {
    fs.writeFileSync(threadEnvFile, generateThreadEnv(name, dbName, dbUser, dbPass, tribePort, junctionPort, distPort, distPhpPort));
  } else {
    warn('.env already exists — skipping (using existing credentials).');
    effectiveDbPass = '(from existing .env)';
  }

  // ── Provision MySQL ─────────────────────────────────────────────────────────
  provisionDb(dbName, dbUser, effectiveDbPass === '(from existing .env)' ? dbPass : effectiveDbPass);

  // ── Register ────────────────────────────────────────────────────────────────
  registryAdd(name, tribePort, junctionPort, distPort, distPhpPort, dbName, dbUser);

  // ── Start containers ────────────────────────────────────────────────────────
  info('Starting Thread containers...');
  dockerCompose(path.join(threadDir, 'docker-compose.yml'), ['up', '-d']);

  console.log('');
  log(`Thread '${name}' is up!`);
  console.log('');
  console.log(`  ${CYAN}Tribe:${NC}    http://localhost:${tribePort}`);
  console.log(`  ${CYAN}Junction:${NC} http://localhost:${junctionPort}`);
  console.log(`  ${CYAN}Dist:${NC}     http://localhost:${distPort}`);
  console.log(`  ${CYAN}Dist PHP:${NC} http://localhost:${distPhpPort}`);
  console.log(`  ${CYAN}DB:${NC}       ${dbName}  (user: ${dbUser})`);
  console.log('');
}

async function cmdDestroy(name) {
  if (!name) die('Usage: loom.js destroy <n>');

  loadEnv();
  registryInit();
  if (!registryHas(name)) die(`Thread '${name}' not found in registry.`);

  const threadDir = path.join(THREADS_DIR, name);
  const dbName    = registryGet(name, 'db_name');
  const dbUser    = registryGet(name, 'db_user');

  console.log('');
  warn(`This will stop Thread '${name}' and drop its database.`);
  warn(`Thread directory will be archived to uploads/threads/time()-${name}.`);
  warn(`Database '${dbName}' will be DROPPED.`);
  warn(`The entire thread directory threads/${name}/ will be removed, including uploads.`);
  console.log('');

  const confirm = await prompt('Type the thread name to confirm: ');
  if (confirm !== name) die('Aborted.');

  info('Stopping containers...');
  dockerCompose(path.join(threadDir, 'docker-compose.yml'), ['down', '-v']);

  dropDb(dbName, dbUser);

  info('Archiving thread directory...');
  const uploadsThreadsDir = path.join(SCRIPT_DIR, 'uploads', 'threads');
  fs.mkdirSync(uploadsThreadsDir, { recursive: true });
  const archiveName = `${Date.now()}-${name}`;
  const archiveDest = path.join(uploadsThreadsDir, archiveName);
  fs.renameSync(threadDir, archiveDest);
  log(`Thread directory archived to uploads/threads/${archiveName}`);

  registryRemove(name);

  log(`Thread '${name}' destroyed.`);
  console.log('');
}

function cmdList() {
  loadEnv();
  registryInit();

  console.log('');
  console.log(`${BOLD}Loom Threads${NC}`);
  console.log('────────────────────────────────────────────────────────────────');

  const data    = registryRead();
  const threads = data.threads || {};

  if (!Object.keys(threads).length) {
    console.log('  (no threads provisioned yet)');
  } else {
    // Get running containers
    const psResult = spawnSync('docker', ['ps', '--format', '{{.Names}}'], { stdio: 'pipe' });
    const running  = new Set(
      (psResult.stdout || '').toString().split('\n').map(s => s.trim()).filter(Boolean)
    );

    const fmt = (thread, tribe, jxn, status, db) =>
      `  ${thread.padEnd(20)} ${String(tribe).padStart(6)}  ${String(jxn).padStart(6)}  ${db}`;

    console.log(fmt('THREAD', 'TRIBE', 'JXN', 'STATUS', 'DB'));
    console.log('  ' + '-'.repeat(68));

    const prefix = data.project_name || 'tribe';
    for (const [tname, t] of Object.entries(threads).sort()) {
      const expected = [
        `${prefix}_${tname}_php_tribe`,
        `${prefix}_${tname}_caddy_tribe`,
        `${prefix}_${tname}_php_junction`,
        `${prefix}_${tname}_caddy_junction`,
      ];
      const alive = expected.filter(c => running.has(c)).length;
      let status;
      if (alive === expected.length) {
        status = `${GREEN}● running${NC}`;
      } else if (alive > 0) {
        status = `${YELLOW}◑ partial (${alive}/${expected.length})${NC}`;
      } else {
        status = `${RED}○ stopped${NC}`;
      }
      console.log(fmt(tname, t.tribe_port, t.junction_port, '', t.db_name));
      console.log(`  ${''.padEnd(20)} ${''.padStart(6)}  ${''.padStart(6)}  ${status}`);
    }
  }

  console.log('');
  const next = registryNextPort();
  console.log(`  ${CYAN}Next available port:${NC} ${next}`);
  console.log('');
}

function cmdStart(name) {
  if (!name) die('Usage: loom.js start <n>');

  loadEnv();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);

  info(`Starting thread '${name}'...`);
  dockerCompose(path.join(THREADS_DIR, name, 'docker-compose.yml'), ['up', '-d']);
  log(`Thread '${name}' started.`);
}

function cmdStop(name) {
  if (!name) die('Usage: loom.js stop <n>');

  loadEnv();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);

  info(`Stopping thread '${name}'...`);
  dockerCompose(path.join(THREADS_DIR, name, 'docker-compose.yml'), ['stop']);
  log(`Thread '${name}' stopped.`);
}

function cmdLogs(name, service) {
  if (!name) die('Usage: loom.js logs <n> [service]');

  loadEnv();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);

  const args = ['compose', '-f', path.join(THREADS_DIR, name, 'docker-compose.yml'), 'logs', '-f'];
  if (service) args.push(service);

  // Use spawn (not spawnSync) to stream logs live
  const child = spawn('docker', args, { stdio: 'inherit' });
  child.on('exit', code => process.exit(code || 0));
}

function cmdStatus(name) {
  if (!name) die('Usage: loom.js status <n>');

  loadEnv();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);

  dockerCompose(path.join(THREADS_DIR, name, 'docker-compose.yml'), ['ps']);
}

function cmdRecreateConfig(name) {
  if (!name) die('Usage: loom.js recreate-config <n>');

  loadEnv();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);

  const threadDir    = path.join(THREADS_DIR, name);
  const tribePort    = Number(registryGet(name, 'tribe_port'));
  const junctionPort = Number(registryGet(name, 'junction_port'));
  const distPort     = Number(registryGet(name, 'dist_port'));
  const distPhpPort  = Number(registryGet(name, 'dist_php_port'));

  warn(`Regenerating docker-compose.yml and Caddyfiles for '${name}'.`);
  warn('Existing .env is preserved.');

  fs.writeFileSync(path.join(threadDir, 'config', 'tribe',    'Caddyfile'), generateTribeCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'junction', 'Caddyfile'), generateJunctionCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'dist',     'Caddyfile'), generateDistCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'dist-php', 'Caddyfile'), generateDistPhpCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'docker-compose.yml'),              generateThreadCompose(name, tribePort, junctionPort, distPort, distPhpPort));

  if (fs.existsSync(SUPERVISORD_CONF)) {
    fs.copyFileSync(SUPERVISORD_CONF, path.join(threadDir, 'config', 'tribe', 'supervisord.conf'));
  } else {
    warn(`supervisord.conf not found at ${SUPERVISORD_CONF} — skipping copy.`);
  }
  if (fs.existsSync(BACKUP_SH)) {
    fs.copyFileSync(BACKUP_SH, path.join(threadDir, 'config', 'backup.sh'));
  } else {
    warn(`backup.sh not found at ${BACKUP_SH} — skipping copy.`);
  }

  log(`Config regenerated. Run 'loom.js start ${name}' to apply.`);
}

// ─── upgrade-docker ───────────────────────────────────────────────────────────
// Stops the thread, regenerates docker-compose.yml (and Caddyfiles), then
// restarts it.  No data is touched: uploads, logs, custom, and .env are all
// left exactly as-is.  Named volumes (caddy data/config) are also preserved
// because we do NOT pass `-v` to `down`.
function cmdUpgradeDocker(name) {
  if (!name) die('Usage: loom.js upgrade-docker <n>');

  loadEnv();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);

  const threadDir    = path.join(THREADS_DIR, name);
  const composeFile  = path.join(threadDir, 'docker-compose.yml');
  const tribePort    = Number(registryGet(name, 'tribe_port'));
  const junctionPort = Number(registryGet(name, 'junction_port'));
  const distPort     = Number(registryGet(name, 'dist_port'));
  const distPhpPort  = Number(registryGet(name, 'dist_php_port'));

  console.log('');
  console.log(`${BOLD}Upgrading Docker config for Thread: ${CYAN}${name}${NC}`);
  console.log('');

  // 1. Stop containers (no -v so named volumes are kept)
  info('Stopping containers...');
  dockerCompose(composeFile, ['down']);

  // 2. Regenerate configs
  info('Regenerating Caddyfiles...');
  fs.writeFileSync(path.join(threadDir, 'config', 'tribe',    'Caddyfile'), generateTribeCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'junction', 'Caddyfile'), generateJunctionCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'dist',     'Caddyfile'), generateDistCaddyfile(name));
  fs.writeFileSync(path.join(threadDir, 'config', 'dist-php', 'Caddyfile'), generateDistPhpCaddyfile(name));

  if (fs.existsSync(SUPERVISORD_CONF)) {
    fs.copyFileSync(SUPERVISORD_CONF, path.join(threadDir, 'config', 'tribe', 'supervisord.conf'));
  } else {
    warn(`supervisord.conf not found at ${SUPERVISORD_CONF} — skipping copy.`);
  }
  if (fs.existsSync(BACKUP_SH)) {
    fs.copyFileSync(BACKUP_SH, path.join(threadDir, 'config', 'backup.sh'));
  } else {
    warn(`backup.sh not found at ${BACKUP_SH} — skipping copy.`);
  }

  info('Regenerating docker-compose.yml...');
  fs.writeFileSync(composeFile, generateThreadCompose(name, tribePort, junctionPort, distPort, distPhpPort));

  // 3. Pull latest images (optional but useful when upgrading)
  info('Pulling latest images...');
  dockerCompose(composeFile, ['pull']);

  // 4. Start back up
  info('Starting containers with new config...');
  dockerCompose(composeFile, ['up', '-d']);

  console.log('');
  log(`Thread '${name}' upgraded and restarted.`);
  console.log(`  ${CYAN}Tribe:${NC}    http://localhost:${tribePort}`);
  console.log(`  ${CYAN}Junction:${NC} http://localhost:${junctionPort}`);
  console.log(`  ${CYAN}Dist:${NC}     http://localhost:${distPort}`);
  console.log(`  ${CYAN}Dist PHP:${NC} http://localhost:${distPhpPort}`);
  console.log('');
}

function usage() {
  console.log(`Usage: loom.js <command> [args]

  create          <n>       Provision and start a new Thread
  destroy         <n>       Stop containers, drop DB, remove thread dir
  list                      List all Threads with ports and status
  start           <n>       Start a stopped Thread
  stop            <n>       Stop a running Thread
  logs            <n> [svc] Tail logs (svc: php_tribe|caddy_tribe|php_junction|caddy_junction)
  status          <n>       Show container status
  recreate-config <n>       Regenerate compose + Caddyfiles (keeps .env)
  upgrade-docker  <n>       Stop thread, regenerate compose, pull images, restart
`);
  process.exit(1);
}

// ─── Dispatch ─────────────────────────────────────────────────────────────────
(async () => {
  const [,, cmd, arg1, arg2] = process.argv;

  switch (cmd) {
    case 'create':          await cmdCreate(arg1);        break;
    case 'destroy':         await cmdDestroy(arg1);       break;
    case 'list':            cmdList();                    break;
    case 'start':           cmdStart(arg1);               break;
    case 'stop':            cmdStop(arg1);                break;
    case 'logs':            cmdLogs(arg1, arg2);          break;
    case 'status':          cmdStatus(arg1);              break;
    case 'recreate-config': cmdRecreateConfig(arg1);      break;
    case 'upgrade-docker':  cmdUpgradeDocker(arg1);       break;
    default:                usage();
  }
})();
