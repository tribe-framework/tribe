function generateThreadCompose(name, tribePort, junctionPort, distPort, distPhpPort) {
  const tsKey   = TYPESENSE_API_KEY;
  const project = PROJECT_NAME;
  const network = `${project}_network`;
  const tsHost  = `${project}_typesense`;

  // All mounts are relative to the thread directory itself — everything
  // lives under threads/<name>/ so the folder is fully self-contained.
  return `# Auto-generated by loom.js — do not edit manually.
# Regenerate with: loom.js recreate-config ${name}

services:

  php_tribe:
    image: tribeframework/tribe-core:v1.2
    platform: linux/amd64
    container_name: ${project}_${name}_php_tribe
    restart: unless-stopped
    env_file:
      - .env
    environment:
      - PROJECT_NAME=${project}_${name}
      - TYPESENSE_HOST=${tsHost}
      - TYPESENSE_PORT=8108
      - TYPESENSE_API_KEY=${tsKey}
      - TYPESENSE_COLLECTION_PREFIX=${name}
      - COLLECTION_NAME=${name}_files
      - INDEX_FOLDER=/var/www/html/uploads
      - INDEX_DB_SCRIPT=/var/www/html/config/index_db.php
    volumes:
      - ./uploads:/var/www/html/uploads
      - ./applications/tribe/custom:/var/www/html/custom
      - ./logs:/var/log
      - ./config/tribe/supervisord.conf:/etc/supervisor/conf.d/tribe.conf
      - ../../../applications/tribe:/var/www/html:ro
    command: >
      sh -c "
        exec supervisord -c /etc/supervisor/conf.d/tribe.conf
      "
    networks:
      - thread_network

  php_junction:
    image: tribeframework/tribe-core:v1.2
    platform: linux/amd64
    container_name: ${project}_${name}_php_junction
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - ./uploads:/var/www/html/uploads
      - ./logs:/var/log
      - ../../../applications/junction/dist:/var/www/html:ro
    command: >
      sh -c "
        if [ -f composer.json ]; then composer install --no-interaction --optimize-autoloader; fi &&
        php-fpm
      "
    networks:
      - thread_network

  caddy_tribe:
    image: caddy:2-alpine
    container_name: ${project}_${name}_caddy_tribe
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "${tribePort}:80"
    volumes:
      - ./applications/tribe/custom:/var/www/html/custom
      - ./uploads:/var/www/html/uploads
      - ./logs:/var/log/caddy
      - ../../../applications/tribe:/var/www/html:ro
      - ./config/tribe/Caddyfile:/etc/caddy/Caddyfile:ro
      - tribe_caddy_data:/data
      - tribe_caddy_config:/config
    depends_on:
      - php_tribe
    networks:
      - thread_network

  caddy_junction:
    image: caddy:2-alpine
    container_name: ${project}_${name}_caddy_junction
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "${junctionPort}:80"
    volumes:
      - ./uploads:/var/www/html/uploads
      - ./logs:/var/log/caddy
      - ./config/junction/Caddyfile:/etc/caddy/Caddyfile:ro
      - ../../../applications/junction/dist:/var/www/html:ro
      - junction_caddy_data:/data
      - junction_caddy_config:/config
    depends_on:
      - php_junction
    networks:
      - thread_network

  mysql_backup:
    image: mysql:9
    container_name: ${project}_${name}_mysql_backup
    restart: unless-stopped
    volumes:
      - ./uploads/backups:/backups
      - ./config/backup.sh:/backup.sh
      - /etc/localtime:/etc/localtime:ro
    env_file:
      - .env
    environment:
      - MYSQL_PWD=\${DB_ROOT_PASSWORD}
      - DB_NAME=\${DB_NAME}
      - DB_HOST=\${DB_HOST}
      - PROJECT_NAME=${project}_${name}
    command: ["bash", "/backup.sh"]
    networks:
      - thread_network

  caddy_dist:
    image: caddy:2-alpine
    container_name: ${project}_${name}_caddy_dist
    restart: unless-stopped
    ports:
      - "${distPort}:80"
    volumes:
      - ./uploads/sites/dist:/srv
      - ./logs:/var/log/caddy
      - ./config/dist/Caddyfile:/etc/caddy/Caddyfile:ro
    networks:
      - thread_network

  php_dist:
    image: tribeframework/tribe-core:v1.2
    platform: linux/amd64
    container_name: ${project}_${name}_php_dist
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - ./uploads/sites/dist-php:/var/www/html
      - ./uploads:/var/www/html/uploads
      - ./logs:/var/log
    command: >
      sh -c "if [ -f composer.json ]; then composer install --no-interaction --optimize-autoloader; fi &&
           php-fpm"
    networks:
      - thread_network

  caddy_php_dist:
    image: caddy:2-alpine
    container_name: ${project}_${name}_caddy_php_dist
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "${distPhpPort}:80"
    volumes:
      - ./uploads/sites/dist-php:/var/www/html
      - ./uploads:/var/www/html/uploads
      - ./logs:/var/log/caddy
      - ./config/dist-php/Caddyfile:/etc/caddy/Caddyfile:ro
      - dist_php_caddy_data:/data
      - dist_php_caddy_config:/config
    depends_on:
      - php_dist
    networks:
      - thread_network

networks:
  thread_network:
    external: true
    name: ${network}

volumes:
  tribe_caddy_data:
    name: ${project}_${name}_tribe_caddy_data
  tribe_caddy_config:
    name: ${project}_${name}_tribe_caddy_config
  junction_caddy_data:
    name: ${project}_${name}_junction_caddy_data
  junction_caddy_config:
    name: ${project}_${name}_junction_caddy_config
  dist_php_caddy_data:
    name: ${project}_${name}_dist_php_caddy_data
  dist_php_caddy_config:
    name: ${project}_${name}_dist_php_caddy_config
