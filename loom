#!/usr/bin/env node
// ══════════════════════════════════════════════════════════════════════════════
// loom — Thread lifecycle management CLI
//
// Commands:
//   node loom create         <n>       Provision and start a new Thread
//   node loom destroy        <n>       Stop, remove containers + drop DB
//   node loom list                     List all Threads with ports and status
//   node loom start          <n>       Start a stopped Thread
//   node loom stop           <n>       Stop a running Thread
//   node loom logs           <n> [svc] Tail logs (svc: php_tribe|caddy_tribe|…)
//   node loom status         <n>       Show container status for a Thread
//   node loom recreate-config <n>      Regenerate compose + Caddyfiles (keeps .env)
//   node loom upgrade-docker  <n>      Stop thread, regenerate compose, restart
//
// Prerequisites:
//   - docker compose up -d
//   - applications/tribe/ contains the Tribe code
//   - applications/junction/ contains the Junction code
//
// Thread directory layout (everything self-contained under threads/<name>/):
//   threads/<name>/
//     docker-compose.yml
//     .env
//     config/tribe/Caddyfile
//     config/tribe/supervisord.conf
//     config/junction/Caddyfile
//     config/dist/Caddyfile
//     config/dist-php/Caddyfile
//     config/backup.sh
//     applications/tribe/custom/   ← per-thread Tribe customisations
//     uploads/                     ← user-uploaded files
//     logs/                        ← container logs
//
// ══════════════════════════════════════════════════════════════════════════════

'use strict';

const fs   = require('fs');
const path = require('path');
const { execSync, spawnSync, spawn } = require('child_process');
const readline = require('readline');
const crypto = require('crypto');

// ─── Paths ────────────────────────────────────────────────────────────────────
const SCRIPT_DIR  = __dirname;
const THREADS_DIR = path.join(SCRIPT_DIR, 'threads');
const REGISTRY    = path.join(THREADS_DIR, '.registry.json');
const ENV_FILE    = path.join(SCRIPT_DIR, '.env');
const TRIBE_BASE        = path.join(SCRIPT_DIR, 'applications', 'tribe');
const SUPERVISORD_CONF  = path.join(SCRIPT_DIR, 'config', 'tribe', 'supervisord.conf');
const BACKUP_SH         = path.join(SCRIPT_DIR, 'config', 'backup.sh');

// Resolved after loadEnv()
let LOOM_MYSQL_CONTAINER = '';
let LOOM_NETWORK         = '';
let THREAD_BASE_PORT     = 13000;

// Env values populated by loadEnv()
let PROJECT_NAME      = 'tribe';
let DB_ROOT_PASSWORD  = 'rootpassword';
let TYPESENSE_API_KEY = 'xyz';
let BARE_URL          = 'localhost';
let CONTACT_EMAIL     = 'your@email.com';
let DEFAULT_TIMEZONE  = 'Asia/Kolkata';

// ─── Colours ─────────────────────────────────────────────────────────────────
const RED    = '\x1b[0;31m';
const GREEN  = '\x1b[0;32m';
const YELLOW = '\x1b[1;33m';
const CYAN   = '\x1b[0;36m';
const BOLD   = '\x1b[1m';
const NC     = '\x1b[0m';

const log  = (...a) => console.log(`${GREEN}✓${NC}  ${a.join(' ')}`);
const warn = (...a) => console.log(`${YELLOW}⚠${NC}  ${a.join(' ')}`);
const err  = (...a) => console.error(`${RED}✗${NC}  ${a.join(' ')}`);
const info = (...a) => console.log(`${CYAN}→${NC}  ${a.join(' ')}`);
const die  = (...a) => { err(...a); process.exit(1); };

// ─── Load Loom env ────────────────────────────────────────────────────────────
function loadEnv() {
  if (!fs.existsSync(ENV_FILE)) {
    die('.env not found. Copy .env.sample and fill in values.');
  }

  const raw = fs.readFileSync(ENV_FILE, 'utf8');
  for (const line of raw.split('\n')) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#')) continue;
    const eqIdx = trimmed.indexOf('=');
    if (eqIdx === -1) continue;
    const key = trimmed.slice(0, eqIdx).trim();
    const val = trimmed.slice(eqIdx + 1).trim()
      // Strip surrounding quotes if present
      .replace(/^(['"])(.*)\1$/, '$2');
    process.env[key] = val;
  }

  THREAD_BASE_PORT    = parseInt(process.env.THREAD_BASE_PORT  || '13000', 10);
  DB_ROOT_PASSWORD    = process.env.DB_ROOT_PASSWORD            || 'rootpassword';
  PROJECT_NAME        = process.env.PROJECT_NAME                || 'tribe';
  TYPESENSE_API_KEY   = process.env.TYPESENSE_API_KEY           || 'xyz';
  BARE_URL            = process.env.BARE_URL                    || 'localhost';
  CONTACT_EMAIL       = process.env.CONTACT_EMAIL               || 'your@email.com';
  DEFAULT_TIMEZONE    = process.env.DEFAULT_TIMEZONE            || 'Asia/Kolkata';

  LOOM_MYSQL_CONTAINER = `${PROJECT_NAME}_mysql`;
  LOOM_NETWORK         = `${PROJECT_NAME}_network`;
}

// ─── Registry helpers ─────────────────────────────────────────────────────────
function registryInit() {
  fs.mkdirSync(THREADS_DIR, { recursive: true });
  if (!fs.existsSync(REGISTRY)) {
    fs.writeFileSync(REGISTRY, JSON.stringify({
      project_name: PROJECT_NAME,
      threads: {},
      next_port: THREAD_BASE_PORT,
    }, null, 2));
  }
}

function registryRead() {
  return JSON.parse(fs.readFileSync(REGISTRY, 'utf8'));
}

function registryWrite(data) {
  fs.writeFileSync(REGISTRY, JSON.stringify(data, null, 2));
}

function registryGet(name, field) {
  const data = registryRead();
  const thread = (data.threads || {})[name];
  if (!thread) return null;
  return thread[field] !== undefined ? String(thread[field]) : '';
}

function registryHas(name) {
  const data = registryRead();
  return name in (data.threads || {});
}

function registryAdd(name, tribePort, junctionPort, distPort, distPhpPort, dbName, dbUser) {
  const data = registryRead();
  const basePort = tribePort; // tribePort is always basePort+0
  data.threads[name] = {
    base_port:      basePort,
    tribe_port:     tribePort,
    junction_port:  junctionPort,
    dist_port:      distPort,
    dist_php_port:  distPhpPort,
    db_name:        dbName,
    db_user:        dbUser,
    created_at:     new Date().toISOString(),
  };
  data.next_port = basePort + 10;  // reserve a full block of 10
  registryWrite(data);
}

function registryRemove(name) {
  const data = registryRead();
  delete data.threads[name];
  registryWrite(data);
}

function registryNextPort() {
  const data = registryRead();
  return data.next_port !== undefined ? data.next_port : THREAD_BASE_PORT;
}

function registryList() {
  const data = registryRead();
  const threads = data.threads || {};
  if (!Object.keys(threads).length) {
    console.log('  (no threads)');
    return;
  }
  for (const [name, t] of Object.entries(threads).sort()) {
    const created = t.created_at ? t.created_at.slice(0, 10) : '';
    console.log(`  ${name}  tribe=${t.tribe_port}  junction=${t.junction_port}  dist=${t.dist_port}  dist-php=${t.dist_php_port}  db=${t.db_name}  created=${created}`);
  }
}

// ─── Name validation ─────────────────────────────────────────────────────────
function validateName(name) {
  if (!/^[a-z0-9][a-z0-9-]{1,30}$/.test(name)) {
    die(`Thread name must be 2–31 chars, lowercase letters/numbers/hyphens, start with alphanumeric. Got: '${name}'`);
  }
}

// ─── Prerequisite checks ─────────────────────────────────────────────────────
function checkPrerequisites() {
  // docker available?
  const dockerCheck = spawnSync('docker', ['--version'], { stdio: 'pipe' });
  if (dockerCheck.status !== 0) die('docker not found');

  // network exists?
  const netCheck = spawnSync('docker', ['network', 'inspect', LOOM_NETWORK], { stdio: 'pipe' });
  if (netCheck.status !== 0) {
    die(`Network '${LOOM_NETWORK}' not found. Run: docker compose --profile loom up -d`);
  }

  // mysql container running?
  const psResult = spawnSync('docker', ['ps', '--format', '{{.Names}}'], { stdio: 'pipe' });
  const running = (psResult.stdout || '').toString().split('\n').map(s => s.trim());
  if (!running.includes(LOOM_MYSQL_CONTAINER)) {
    die(`MySQL container '${LOOM_MYSQL_CONTAINER}' is not running. Start Loom first: docker compose --profile loom up -d`);
  }

  // tribe base dir exists?
  if (!fs.existsSync(TRIBE_BASE)) {
    die(`Tribe base app not found at: ${TRIBE_BASE}\nPlace the Tribe app code there before creating threads.`);
  }
}

