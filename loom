// ─── upgrade-docker ───────────────────────────────────────────────────────────
// Stops the thread, regenerates docker-compose.yml (and Caddyfiles), then
// restarts it.  No data is touched: uploads, logs, custom, and .env are all
// left exactly as-is.  Named volumes (caddy data/config) are also preserved
// because we do NOT pass `-v` to `down`.
function cmdUpgradeDocker(name) {
  if (!name) die('Usage: node loom upgrade-docker <n>');

  loadEnv();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);

  const threadDir    = path.join(THREADS_DIR, name);
  const composeFile  = path.join(threadDir, 'docker-compose.yml');
  const tribePort    = Number(registryGet(name, 'tribe_port'));
  const junctionPort = Number(registryGet(name, 'junction_port'));
  const distPort     = Number(registryGet(name, 'dist_port'));
  const distPhpPort  = Number(registryGet(name, 'dist_php_port'));

  console.log('');
  console.log(`${BOLD}Upgrading Docker config for Thread: ${CYAN}${name}${NC}`);
  console.log('');

  // 1. Stop containers (no -v so named volumes are kept)
  info('Stopping containers...');
  dockerCompose(composeFile, ['down']);

  // 2. Regenerate configs
  info('Regenerating Caddyfiles...');
  const tribeDomain_u    = registryGet(name, 'tribe_domain')    || '';
  const junctionDomain_u = registryGet(name, 'junction_domain') || '';
  const distDomain_u     = registryGet(name, 'dist_domain')     || '';
  const distPhpDomain_u  = registryGet(name, 'dist_php_domain') || '';
  fs.writeFileSync(path.join(threadDir, 'config', 'tribe',    'Caddyfile'), generateTribeCaddyfile(name, tribeDomain_u));
  fs.writeFileSync(path.join(threadDir, 'config', 'junction', 'Caddyfile'), generateJunctionCaddyfile(name, junctionDomain_u));
  fs.writeFileSync(path.join(threadDir, 'config', 'dist',     'Caddyfile'), generateDistCaddyfile(name, distDomain_u));
  fs.writeFileSync(path.join(threadDir, 'config', 'dist-php', 'Caddyfile'), generateDistPhpCaddyfile(name, distPhpDomain_u));

  info('Regenerating docker-compose.yml...');
  fs.writeFileSync(composeFile, generateThreadCompose(name, tribePort, junctionPort, distPort, distPhpPort, { tribe: tribeDomain_u, junction: junctionDomain_u, dist: distDomain_u, distPhp: distPhpDomain_u }));

  // 3. Pull latest images (optional but useful when upgrading)
  info('Pulling latest images...');
  dockerCompose(composeFile, ['pull']);

  // 4. Start back up
  info('Starting containers with new config...');
  dockerCompose(composeFile, ['up', '-d']);

  console.log('');
  log(`Thread '${name}' upgraded and restarted.`);
  console.log(`  ${CYAN}Tribe:${NC}    http://${BARE_URL}:${tribePort}`);
  console.log(`  ${CYAN}Junction:${NC} http://${BARE_URL}:${junctionPort}`);
  console.log(`  ${CYAN}Dist:${NC}     http://${BARE_URL}:${distPort}`);
  console.log(`  ${CYAN}Dist PHP:${NC} http://${BARE_URL}:${distPhpPort}`);
  console.log('');
}

// ─── set-junction-password ────────────────────────────────────────────────────
// Updates JUNCTION_PASSWORD in threads/<n>/.env and restarts junction
// containers so the change takes effect immediately.
async function cmdSetJunctionPassword(name) {
  if (!name) die('Usage: node loom set-junction-password <n> [password]');

  loadEnv();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);

  const threadDir = path.join(THREADS_DIR, name);
  const envFile   = path.join(threadDir, '.env');

  if (!fs.existsSync(envFile)) die(`No .env found for thread '${name}' at ${envFile}`);

  // Use supplied arg or prompt interactively
  let newPassword = process.argv[4] || '';
  if (!newPassword) {
    newPassword = await prompt('New JUNCTION_PASSWORD: ');
  }
  newPassword = newPassword.trim();
  if (!newPassword) die('Password cannot be empty.');

  // Read .env, replace or append JUNCTION_PASSWORD
  let envContent = fs.readFileSync(envFile, 'utf8');

  if (/^JUNCTION_PASSWORD=.*$/m.test(envContent)) {
    envContent = envContent.replace(/^JUNCTION_PASSWORD=.*$/m, `JUNCTION_PASSWORD=${newPassword}`);
    info('Updated existing JUNCTION_PASSWORD.');
  } else {
    envContent += `\nJUNCTION_PASSWORD=${newPassword}\n`;
    warn('JUNCTION_PASSWORD was not present — appended to .env.');
  }

  fs.writeFileSync(envFile, envContent);
  log(`.env updated for thread '${name}'.`);

  // Restart only the junction containers so the new password is picked up
  const composeFile = path.join(threadDir, 'docker-compose.yml');
  info('Restarting junction containers...');
  dockerCompose(composeFile, ['restart', 'php_junction', 'caddy_junction']);
  log(`Junction containers restarted. JUNCTION_PASSWORD updated for thread '${name}'.`);
}

// ─── set-*-domain helpers ─────────────────────────────────────────────────────
// Shared implementation for all four domain-binding commands.
//
// What it does:
//   1. Validates the domain looks plausible (not empty, contains a dot).
//   2. Rewrites the relevant Caddyfile so Caddy listens on the domain name
//      instead of bare :80 — this is what triggers Caddy's automatic
//      ACME / Let's Encrypt certificate provisioning.
//   3. Updates docker-compose.yml to also expose port 443 on that service
//      so TLS traffic can reach the container from the host.
//   4. Persists the mapping in .registry.json so recreate-config and
//      upgrade-docker keep the domain after a regeneration.
//   5. Reloads only the affected Caddy container (docker compose restart)
//      so the other services keep running without interruption.
//
// Prerequisites the caller must have handled:
//   - The A / CNAME record for the domain already points at this server.
//   - Port 80 and 443 are open in the firewall (Caddy needs 80 for the
//     ACME HTTP-01 challenge even when the final cert is served on 443).

function validateDomain(domain) {
  if (!domain || !domain.includes('.')) {
    die(`'${domain}' does not look like a valid domain name.`);
  }
  if (/\s/.test(domain)) {
    die(`Domain must not contain spaces: '${domain}'`);
  }
}

function cmdSetDomain(name, domain, service, registryField, caddyfileGenerator, caddyService) {
  if (!name || !domain) die(`Usage: node loom ${service} <thread> <domain>`);

  loadEnv();
  registryInit();
  if (!registryHas(name)) die(`Thread '${name}' not found.`);
  validateDomain(domain);

  const threadDir    = path.join(THREADS_DIR, name);
  const composeFile  = path.join(threadDir, 'docker-compose.yml');

  // 1. Rewrite the Caddyfile for this service
  const caddyfilePath = path.join(threadDir, 'config', ...{
    tribe:    ['tribe',    'Caddyfile'],
    junction: ['junction', 'Caddyfile'],
    dist:     ['dist',     'Caddyfile'],
    distPhp:  ['dist-php', 'Caddyfile'],
  }[registryField]);

  info(`Writing Caddyfile for domain '${domain}'...`);
  fs.writeFileSync(caddyfilePath, caddyfileGenerator(name, domain));

  // 2. Persist domain in registry
  const domainRegistryKey = {
    tribe:    'tribe_domain',
    junction: 'junction_domain',
    dist:     'dist_domain',
    distPhp:  'dist_php_domain',
  }[registryField];
  registrySetDomain(name, domainRegistryKey, domain);

  // 3. Regenerate docker-compose.yml so port 443 is exposed for this service
  const tribePort    = Number(registryGet(name, 'tribe_port'));
  const junctionPort = Number(registryGet(name, 'junction_port'));
  const distPort     = Number(registryGet(name, 'dist_port'));
  const distPhpPort  = Number(registryGet(name, 'dist_php_port'));
  const domains = {
    tribe:    registryGet(name, 'tribe_domain')    || '',
    junction: registryGet(name, 'junction_domain') || '',
    dist:     registryGet(name, 'dist_domain')     || '',
    distPhp:  registryGet(name, 'dist_php_domain') || '',
  };

  info('Regenerating docker-compose.yml with updated ports...');
  fs.writeFileSync(composeFile, generateThreadCompose(name, tribePort, junctionPort, distPort, distPhpPort, domains));

  // 4. Reload only the affected Caddy container
  info(`Restarting ${caddyService} to apply domain and obtain SSL certificate...`);
  dockerCompose(composeFile, ['up', '-d', '--no-deps', caddyService]);

  console.log('');
  log(`Domain set for thread '${name}' (${registryField}): https://${domain}`);
  warn('Make sure port 80 and 443 are open in your firewall.');
  warn('Caddy will obtain a Let\'s Encrypt certificate automatically on first request.');
  console.log('');
}

function cmdSetTribeDomain(name, domain) {
  cmdSetDomain(name, domain, 'set-tribe-domain', 'tribe', generateTribeCaddyfile, 'caddy_tribe');
}

function cmdSetJunctionDomain(name, domain) {
  cmdSetDomain(name, domain, 'set-junction-domain', 'junction', generateJunctionCaddyfile, 'caddy_junction');
}

function cmdSetDistDomain(name, domain) {
  cmdSetDomain(name, domain, 'set-dist-domain', 'dist', generateDistCaddyfile, 'caddy_dist');
}

function cmdSetDistPhpDomain(name, domain) {
  cmdSetDomain(name, domain, 'set-dist-php-domain', 'distPhp', generateDistPhpCaddyfile, 'caddy_php_dist');
}

function usage() {
  console.log(`Usage: node loom <command> [args]

  create          <n>         Provision and start a new Thread
  destroy         <n>         Stop containers, drop DB, remove thread dir
  list                        List all Threads with ports and status
  start           <n>         Start a stopped Thread
  stop            <n>         Stop a running Thread
  logs            <n> [svc]   Tail logs (svc: php_tribe|caddy_tribe|php_junction|caddy_junction)
  status          <n>         Show container status
  recreate-config        <n>         Regenerate compose + Caddyfiles (keeps .env)
  upgrade-docker         <n>         Stop thread, regenerate compose, pull images, restart
  set-junction-password  <n> [pw]    Update JUNCTION_PASSWORD in thread .env and restart junction

  Domain / SSL commands (A or CNAME must already point at this server):
  set-tribe-domain       <n> <domain>  Bind tribe to domain + auto-SSL
  set-junction-domain    <n> <domain>  Bind junction to domain + auto-SSL
  set-dist-domain        <n> <domain>  Bind dist (static) to domain + auto-SSL
  set-dist-php-domain    <n> <domain>  Bind dist-php to domain + auto-SSL
`);
  process.exit(1);
}

// ─── Dispatch ─────────────────────────────────────────────────────────────────
(async () => {
  const [,, cmd, arg1, arg2] = process.argv;

  switch (cmd) {
    case 'create':          await cmdCreate(arg1);        break;
    case 'destroy':         await cmdDestroy(arg1);       break;
    case 'list':            cmdList();                    break;
    case 'start':           cmdStart(arg1);               break;
    case 'stop':            cmdStop(arg1);                break;
    case 'logs':            cmdLogs(arg1, arg2);          break;
    case 'status':          cmdStatus(arg1);              break;
    case 'recreate-config': cmdRecreateConfig(arg1);      break;
    case 'upgrade-docker':        cmdUpgradeDocker(arg1);             break;
    case 'set-junction-password': await cmdSetJunctionPassword(arg1); break;
    case 'set-tribe-domain':      cmdSetTribeDomain(arg1, arg2);      break;
    case 'set-junction-domain':   cmdSetJunctionDomain(arg1, arg2);   break;
    case 'set-dist-domain':       cmdSetDistDomain(arg1, arg2);       break;
    case 'set-dist-php-domain':   cmdSetDistPhpDomain(arg1, arg2);    break;
    default:                usage();
  }
})();
